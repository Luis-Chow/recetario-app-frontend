# URL del backend desplegado. Copia este archivo a ".env" y pon tu URL real de Render.
# IMPORTANTE: sin "/api" al final (la app ya lo agrega) y sin "/" final.
#
#   EXPO_PUBLIC_API_URL=https://recetas-backend.onrender.com
#
# Si dejas esto vacio o no creas .env, la app usa http://localhost:4000
# (util para desarrollo con el backend corriendo en tu PC).
EXPO_PUBLIC_API_URL=

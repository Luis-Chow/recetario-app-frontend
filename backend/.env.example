# Puerto en el que escucha el servidor
PORT=4000

# Cadena de conexion a MongoDB. Si esta vacia, se levanta mongodb-memory-server (en RAM).
# Ejemplos:
#   mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/recetas
#   mongodb://localhost:27017/recetas
MONGODB_URI=

# Secreto para firmar JWTs. CAMBIAR EN PRODUCCION.
JWT_SECRET=cambia-este-secreto-en-produccion

# Tiempo de vida del token JWT (formato compatible con `ms`: 7d, 24h, 60m...)
JWT_EXPIRES_IN=7d
